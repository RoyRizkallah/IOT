        android:fillColor="#FFFFFF"
        android:pathData="M54,32
                          C54,32 38,36 32,38
                          C30.5,38.5 30,39.8 30,41
                          L30,58
                          C30,67 36,73.5 41,76.5
                          C46.5,79.7 52,82.5 54,83
                          C56,82.5 61.5,79.7 67,76.5
                          C72,73.5 78,67 78,58
                          L78,41
                          C78,39.8 77.5,38.5 76,38
                          C70,36 54,32 54,32 Z" />

    <!-- Inner accent dot -->
