/sentry_agent/data/
/data/
*.db
*.db-wal
*.db-shm

# Build / dependency caches (defensive — subprojects also ignore these)
node_modules/
.gradle/
build/
dist/

# Python
__pycache__/
*.pyc
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
*.egg-info/
