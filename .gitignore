# OS noise
.DS_Store
Thumbs.db
desktop.ini
*~

# IDE / editor
.vscode/
.idea/
*.iml
*.suo
*.swp
*.swo
.cursor/

# Logs
*.log
logs/

# Secrets — never commit these
.env
.env.*
*.secret
secrets.yaml
*.local.yaml

